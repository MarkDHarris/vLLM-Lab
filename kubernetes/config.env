# Shared configuration for the Kind production simulation.
# Override any value in your shell before running scripts, e.g.:
#   export MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct

CLUSTER_NAME=vllm-cluster

# Official vLLM ARM64 CPU image (Apple Silicon Kind nodes are linux/arm64).
# Already commonly cached locally as vllm/vllm-openai-cpu:latest.
VLLM_IMAGE=vllm/vllm-openai-cpu:latest

# Small, non-gated model that fits a laptop Kind cluster while still exercising
# the real vLLM OpenAI server path used in production CPU demos.
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# Keep KV-cache bounded so the Docker Desktop VM does not OOM.
MAX_MODEL_LEN=2048

# On the CPU backend this flag is the fraction of *host* RAM vLLM may reserve
# (name is historical). Must leave headroom for Kind + kube-system + Ingress.
GPU_MEMORY_UTILIZATION=0.35

# Host port published by Kind -> Ingress controller container port 80.
# Use 8080 to avoid colliding with local services bound to privileged port 80.
INGRESS_HOST_PORT=8080

# Kind node image matching kind v0.32.x defaults.
KIND_NODE_IMAGE=kindest/node:v1.32.2

# Pinned platform components (vendored under manifests/platform/).
INGRESS_MANIFEST=manifests/platform/ingress-nginx.yaml
METRICS_SERVER_MANIFEST=manifests/platform/metrics-server.yaml

# Hugging Face cache on the Mac host (absolute path required by Kind).
HF_CACHE_HOST="${HOME}/.cache/huggingface"

# Path inside the Kind node where the host cache is mounted.
HF_CACHE_NODE=/var/local/huggingface

# Minimum Docker Desktop VM memory recommended for this stack (GiB).
MIN_DOCKER_MEM_GIB=16
